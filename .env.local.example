# Supabase (получите в Settings -> API вашего проекта)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Настройки викторины
# Дата проведения (формат YYYY-MM-DD). Пустое значение = любой день
QUIZ_EVENT_DATE=2026-07-04

# Временное окно доступа (по серверному времени, часовой пояс ниже)
QUIZ_START_HOUR=10
QUIZ_END_HOUR=17
QUIZ_TIMEZONE=Europe/Moscow

# Лимит времени на прохождение (минуты)
QUIZ_TIME_LIMIT_MINUTES=25

# Количество вопросов в одной сессии
QUIZ_QUESTIONS_COUNT=10

# Пароль панели администратора (/admin)
ADMIN_PASSWORD=gerofarm2025

# Для локального тестирования: true = пропустить проверку временного окна
QUIZ_SKIP_TIME_WINDOW=false
